@using MudBlazor
@using Tarantuly.Abstractions
@inject ICrudDataService<Tarantuly.SampleApp.Data.Product, System.Int32> DataService
<MudText Typo="Typo.h5">Product</MudText>
<MudTable T="Tarantuly.SampleApp.Data.Product" Items="@Items" Dense="true" Hover="true">
    <HeaderContent>
        <MudTh>Id</MudTh>
        <MudTh>IsDeleted</MudTh>
        <MudTh>Name</MudTh>
        <MudTh>Price</MudTh>
        <MudTh>RowVersion</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Id">@context.Id</MudTd>
        <MudTd DataLabel="IsDeleted">@context.IsDeleted</MudTd>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Price">@context.Price</MudTd>
        <MudTd DataLabel="RowVersion">@context.RowVersion</MudTd>
        <MudTd>
            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => OnDetails.InvokeAsync(context)">Details</MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="() => OnEdit.InvokeAsync(context)">Edit</MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteAsync(context)">Delete</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>
@code {
    private List<Tarantuly.SampleApp.Data.Product> Items = [];
    [Parameter] public EventCallback<Tarantuly.SampleApp.Data.Product> OnDetails { get; set; }
    [Parameter] public EventCallback<Tarantuly.SampleApp.Data.Product> OnEdit { get; set; }
    protected override async Task OnInitializedAsync()
    {
        Items = (await DataService.ListAsync()).ToList();
    }
    private async Task DeleteAsync(Tarantuly.SampleApp.Data.Product item)
    {
        await DataService.SoftDeleteAsync(item.Id);
        Items = (await DataService.ListAsync()).ToList();
    }
}
