@using MudBlazor
@using Tarantuly.Abstractions
@inject ICrudDataService<Tarantuly.SampleApp.Data.Product, System.Int32> DataService
<MudForm @ref="_form">
  <MudStack Spacing="2">
    <MudTextField T="string" Label="IsDeleted" Value="@Convert.ToString(Model.IsDeleted)" Disabled="true" />
    <MudTextField T="string" Label="Name" @bind-Value="Model.Name" Required="true" />
    <MudNumericField T="decimal" Label="Price" @bind-Value="Model.Price" Required="true" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Save</MudButton>
  </MudStack>
</MudForm>
@code {
  private MudForm? _form;
  [Parameter] public Tarantuly.SampleApp.Data.Product Model { get; set; } = default!;
  [Parameter] public bool IsEditMode { get; set; }
  [Parameter] public EventCallback<Tarantuly.SampleApp.Data.Product> OnSaved { get; set; }
  private async Task SaveAsync()
  {
    if (_form is not null)
    {
      await _form.Validate();
      if (!_form.IsValid)
      {
        return;
      }
    }
    var saved = IsEditMode
      ? await DataService.UpdateAsync(Model)
      : await DataService.CreateAsync(Model);
    await OnSaved.InvokeAsync(saved);
  }
}
