@using MudBlazor
@using Tarantuly.Abstractions
@inject ICrudDataService<Tarantuly.SampleApp.Data.Product, System.Int32> DataService
<MudText Typo="Typo.h5">Product Details</MudText>
<MudPaper Class="pa-4" Elevation="0">
@if (Model is null)
{
  <MudText Typo="Typo.body2">Loading...</MudText>
}
else
{
  <MudStack Row="true" Class="mb-2">
    <MudText Typo="Typo.subtitle2" Class="me-2">Id:</MudText>
    <MudText Typo="Typo.body2">@Model.Id</MudText>
  </MudStack>
  <MudStack Row="true" Class="mb-2">
    <MudText Typo="Typo.subtitle2" Class="me-2">IsDeleted:</MudText>
    <MudText Typo="Typo.body2">@Model.IsDeleted</MudText>
  </MudStack>
  <MudStack Row="true" Class="mb-2">
    <MudText Typo="Typo.subtitle2" Class="me-2">Name:</MudText>
    <MudText Typo="Typo.body2">@Model.Name</MudText>
  </MudStack>
  <MudStack Row="true" Class="mb-2">
    <MudText Typo="Typo.subtitle2" Class="me-2">Price:</MudText>
    <MudText Typo="Typo.body2">@Model.Price</MudText>
  </MudStack>
  <MudStack Row="true" Class="mb-2">
    <MudText Typo="Typo.subtitle2" Class="me-2">RowVersion:</MudText>
    <MudText Typo="Typo.body2">@Model.RowVersion</MudText>
  </MudStack>
}
</MudPaper>
@code {
  [Parameter] public System.Int32 Id { get; set; } = default!;
  private Tarantuly.SampleApp.Data.Product? Model { get; set; }
  protected override async Task OnParametersSetAsync()
  {
    Model = await DataService.GetByIdAsync(Id);
  }
}
